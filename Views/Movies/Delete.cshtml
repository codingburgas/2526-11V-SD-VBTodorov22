@model MovieDetailsDto
@{
    ViewData["Title"] = "Delete Movie";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 text-danger mb-3">Delete Catalog Item</h1>
                <p>Are you sure you want to delete <strong>@Model.Title</strong>?</p>

                <dl class="row mb-4">
                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8">@Model.CatalogType.GetDisplayName()</dd>

                    <dt class="col-sm-4">Genre</dt>
                    <dd class="col-sm-8">@Model.Genre.GetDisplayName()</dd>

                    <dt class="col-sm-4">Release Year</dt>
                    <dd class="col-sm-8">@Model.ReleaseYear</dd>

                    <dt class="col-sm-4">Director</dt>
                    <dd class="col-sm-8">@Model.DirectorName</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <button type="submit" class="btn btn-danger">Delete</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
