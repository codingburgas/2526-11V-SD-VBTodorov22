@model MovieDetailsDto
@{
    ViewData["Title"] = "Movie Details";
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
        <h1 class="h2 mb-2">@Model.Title</h1>
        <div class="d-flex flex-wrap gap-2">
            <span class="badge text-bg-primary">@Model.CatalogType.GetDisplayName()</span>
            <span class="badge text-bg-secondary">@Model.Genre.GetDisplayName()</span>
            <span class="badge text-bg-light text-dark">@Model.ReleaseYear</span>
        </div>
    </div>
    <div class="text-md-end">
        <div class="rating-number">@Model.AverageRating.ToString("0.0")</div>
        <div class="text-muted">@Model.ReviewCount review(s)</div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5">Description</h2>
                <p class="mb-0 text-secondary">@Model.Description</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Latest Reviews</h2>
                    <a asp-controller="Reviews" asp-action="Index" asp-route-movieId="@Model.Id" class="small text-decoration-none">See all reviews</a>
                </div>
                @if (Model.Reviews.Any())
                {
                    <div class="vstack gap-3">
                        @foreach (var review in Model.Reviews.Take(3))
                        {
                            <div class="border rounded-3 p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="fw-semibold">@review.UserName</div>
                                    <span class="badge text-bg-warning">@review.Rating / 10</span>
                                </div>
                                <div class="small text-muted mb-2">@review.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                                <p class="mb-0">@review.Comment</p>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No reviews have been added yet.</p>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Cover</h2>
                <div class="catalog-cover catalog-cover-lg">
                    @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                    {
                        <img src="@Url.Content(Model.CoverImageUrl)" alt="Cover image for @Model.Title" class="cover-image cover-image-detail" />
                    }
                    else
                    {
                        <div class="catalog-cover-placeholder">
                            <span class="catalog-cover-placeholder-title">@Model.Title</span>
                            <span class="catalog-cover-placeholder-subtitle">Cover image unavailable</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5">Cast &amp; Crew</h2>
                <div class="mb-3">
                    <div class="text-muted small">Director</div>
                    <div class="fw-semibold">@Model.DirectorName</div>
                </div>
                <div>
                    <div class="text-muted small mb-2">Actors</div>
                    @if (Model.Actors.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var actor in Model.Actors)
                            {
                                <span class="badge rounded-pill text-bg-light">@actor</span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No actors assigned.</div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body d-grid gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary">Back to Catalog</a>
                <a asp-controller="Reviews" asp-action="Index" asp-route-movieId="@Model.Id" class="btn btn-outline-primary">Open Reviews</a>
                @if (User.IsInRole("Admin") || User.IsInRole("User"))
                {
                    <a asp-controller="Reviews" asp-action="Create" asp-route-movieId="@Model.Id" class="btn btn-primary">Add Review</a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark">Edit</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" asp-fragment="cover-management" class="btn btn-outline-primary">Manage Cover</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
                }
            </div>
        </div>
    </div>
</div>
