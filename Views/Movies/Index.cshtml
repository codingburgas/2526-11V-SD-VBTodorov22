@model MovieCatalogDto
@{
    ViewData["Title"] = "Movies";
}

<div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
    <div>
        <h1 class="h2 mb-1">Movies &amp; Series Catalog</h1>
        <p class="text-muted mb-0">Filter catalog items by type, genre, and release year.</p>
    </div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary">Create Catalog Item</a>
    }
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label" for="catalogType">Catalog Type</label>
                <select class="form-select" id="catalogType" name="catalogType">
                    <option value="">All types</option>
                    @foreach (var value in Enum.GetValues<CatalogType>())
                    {
                        <option value="@value" selected="@(Model.TypeFilter == value ? "selected" : null)">
                            @value.GetDisplayName()
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label" for="genre">Genre</label>
                <select class="form-select" id="genre" name="genre">
                    <option value="">All genres</option>
                    @foreach (var value in Enum.GetValues<GenreType>())
                    {
                        <option value="@value" selected="@(Model.GenreFilter == value ? "selected" : null)">
                            @value.GetDisplayName()
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label" for="year">Release Year</label>
                <select class="form-select" id="year" name="year">
                    <option value="">All years</option>
                    @foreach (var availableYear in Model.AvailableYears)
                    {
                        <option value="@availableYear" selected="@(Model.YearFilter == availableYear ? "selected" : null)">
                            @availableYear
                        </option>
                    }
                </select>
            </div>
            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn btn-primary">Apply Filters</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (Model.Movies.Any())
{
    <div class="row g-4">
        @foreach (var movie in Model.Movies)
        {
            <div class="col-lg-6">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="row g-3 h-100">
                            <div class="col-md-4">
                                <div class="catalog-cover">
                                    @if (!string.IsNullOrWhiteSpace(movie.CoverImageUrl))
                                    {
                                        <img src="@Url.Content(movie.CoverImageUrl)" alt="Cover image for @movie.Title" class="cover-image cover-image-card" />
                                    }
                                    else
                                    {
                                        <div class="catalog-cover-placeholder">
                                            <span class="catalog-cover-placeholder-title">@movie.Title</span>
                                            <span class="catalog-cover-placeholder-subtitle">No cover</span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-8 d-flex flex-column">
                                <div class="d-flex justify-content-between gap-3 flex-wrap mb-3">
                                    <div>
                                        <h2 class="h4 mb-1">@movie.Title</h2>
                                        <div class="small text-muted">@movie.CatalogType.GetDisplayName() | @movie.Genre.GetDisplayName() | @movie.ReleaseYear</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="rating-number">@movie.AverageRating.ToString("0.0")</div>
                                        <div class="small text-muted">@movie.ReviewCount review(s)</div>
                                    </div>
                                </div>
                                <p class="text-secondary description-snippet">@movie.Description</p>
                                <div class="small text-muted mb-3">Directed by @movie.DirectorName</div>
                                <div class="mt-auto d-flex flex-wrap gap-2">
                                    <a asp-action="Details" asp-route-id="@movie.Id" class="btn btn-outline-primary btn-sm">Details</a>
                                    <a asp-controller="Reviews" asp-action="Index" asp-route-movieId="@movie.Id" class="btn btn-outline-secondary btn-sm">Reviews</a>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-outline-dark btn-sm">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">No catalog items match the selected filters.</div>
}
